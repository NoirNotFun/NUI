            btn.TextColor3 = state and NoirColors.SwitchColor or Color3.fromRGB(180, 180, 180)
            btn.TextSize = 12
            btn.Font = Enum.Font.GothamMedium
            btn.TextXAlignment = Enum.TextXAlignment.Left
            btn.AutoButtonColor = false
            btn.ZIndex = 11
            
            -- Switch
            local switch = Instance.new("Frame", btn)
            switch.Size = UDim2.new(0, 28, 0, 15)
            switch.Position = UDim2.new(1, -36, 0.5, -7.5)
            switch.BackgroundColor3 = state and ACCENT or NoirColors.DropColor
            switch.ZIndex = 12
            Instance.new("UICorner", switch).CornerRadius = UDim.new(1, 0)
            
            local switchInner = Instance.new("Frame", switch)
            switchInner.Size = UDim2.new(0, 11, 0, 11)
            switchInner.Position = state and UDim2.new(1, -13, 0.5, -5.5) or UDim2.new(0, 2, 0.5, -5.5)
            switchInner.BackgroundColor3 = NoirColors.SwitchColor
            switchInner.ZIndex = 13
            Instance.new("UICorner", switchInner).CornerRadius = UDim.new(1, 0)
            
            btn.MouseButton1Click:Connect(function()
                state = not state
                btn.TextColor3 = state and NoirColors.SwitchColor or Color3.fromRGB(180, 180, 180)
                TweenService:Create(switch, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                    BackgroundColor3 = state and ACCENT or NoirColors.DropColor
                }):Play()
                TweenService:Create(switchInner, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                    Position = state and UDim2.new(1, -13, 0.5, -5.5) or UDim2.new(0, 2, 0.5, -5.5)
                }):Play()
                if config.Callback then config.Callback(state) end
            end)
            
            return btn
        end
        
        function Tab:CreateSlider(config)
            config = config or {}
            local min = config.Min or 0
            local max = config.Max or 100
            local defaultValue = config.Default or 50
            local increment = config.Increment or 1
            
            local container = Instance.new("Frame", TabContent)
            container.Size = UDim2.new(0.95, 0, 0, 45)
            container.BackgroundTransparency = 1
            container.ZIndex = 10
            
            local label = Instance.new("TextLabel", container)
            label.Size = UDim2.new(0.7, 0, 0, 20)
            label.Position = UDim2.new(0, 0, 0, 0)
            label.BackgroundTransparency = 1
            label.Text = config.Name or "Slider"
            label.TextColor3 = NoirColors.SwitchColor
            label.TextTransparency = 0.3
            label.TextSize = 12
            label.Font = Enum.Font.GothamMedium
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.ZIndex = 11
            
            local valueLabel = Instance.new("TextLabel", container)
            valueLabel.Size = UDim2.new(0.25, 0, 0, 20)
            valueLabel.Position = UDim2.new(0.75, 0, 0, 0)
            valueLabel.BackgroundTransparency = 1
            valueLabel.Text = tostring(defaultValue) .. (config.Suffix or "")
            valueLabel.TextColor3 = NoirColors.SwitchColor
            valueLabel.TextTransparency = 0.5
            valueLabel.TextSize = 12
            valueLabel.Font = Enum.Font.GothamMedium
            valueLabel.TextXAlignment = Enum.TextXAlignment.Right
            valueLabel.ZIndex = 11
            
            local sliderBg = Instance.new("Frame", container)
            sliderBg.Size = UDim2.new(1, 0, 0, 6)
            sliderBg.Position = UDim2.new(0, 0, 0, 25)
            sliderBg.BackgroundColor3 = NoirColors.DropColor
            sliderBg.ZIndex = 11
            Instance.new("UICorner", sliderBg).CornerRadius = UDim.new(1, 0)
            
            local fill = Instance.new("Frame", sliderBg)
            local percent = (defaultValue - min) / (max - min)
            fill.Size = UDim2.new(percent, 0, 1, 0)
            fill.BackgroundColor3 = ACCENT
            fill.ZIndex = 12
            Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
            
            local handle = Instance.new("Frame", sliderBg)
            handle.Size = UDim2.new(0, 12, 0, 12)
            handle.Position = UDim2.new(percent, -6, 0.5, -6)
            handle.BackgroundColor3 = NoirColors.SwitchColor
            handle.ZIndex = 13
            Instance.new("UICorner", handle).CornerRadius = UDim.new(1, 0)
            
            local function updateSlider(input)
                local p = math.clamp((input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
                local rawValue = min + (max - min) * p
                local value = math.floor((rawValue - min) / increment) * increment + min
                value = math.clamp(value, min, max)
                local newPercent = (value - min) / (max - min)
                
                TweenService:Create(fill, TweenInfo.new(0.05), {
                    Size = UDim2.new(newPercent, 0, 1, 0)
                }):Play()
                TweenService:Create(handle, TweenInfo.new(0.05), {
                    Position = UDim2.new(newPercent, -6, 0.5, -6)
                }):Play()
                
                valueLabel.Text = tostring(value) .. (config.Suffix or "")
                if config.Callback then config.Callback(value) end
            end
            
            local isHeld = false
            sliderBg.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    isHeld = true
                    updateSlider(input)
                end
            end)
            UIS.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    isHeld = false
                end
            end)
            UIS.InputChanged:Connect(function(input)
                if isHeld and input.UserInputType == Enum.UserInputType.MouseMovement then
                    updateSlider(input)
                end
            end)
            
            return container
        end
        
        -- Save Tab
        table.insert(Window.Tabs, Tab)
        return Tab
    end
    
    -- ============================================
    -- 6. DRAG (GIỐNG CK)
    -- ============================================
    local dragToggle = false
    local dragStart, startPos
    
    WindowFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragToggle = true
            dragStart = input.Position
            startPos = WindowFrame.Position
        end
    end)
    
    UIS.InputChanged:Connect(function(input)
        if dragToggle and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            WindowFrame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
    
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragToggle = false
        end
    end)
    
