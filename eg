    -- ============================================
    -- 10. NOTIFICATION
    -- ============================================
    function NoirUI:Notify(title, message, iconName, soundType)
        if soundType then
            PlaySound(soundType)
        else
            PlaySound("Notification")
        end
        
        local n = Instance.new("Frame", ScreenGui)
        n.Size = UDim2.new(0, 260, 0, 65)
        n.Position = UDim2.new(1, 20, 0.8, 0)
        n.BackgroundColor3 = NoirColors.BGDBColor
        n.BackgroundTransparency = 0.2
        n.ZIndex = 50
        Instance.new("UICorner", n).CornerRadius = UDim.new(0, 8)
        
        local stroke = Instance.new("UIStroke", n)
        stroke.Color = ACCENT
        stroke.Thickness = 1
        
        if iconName then
            local icon = Instance.new("ImageLabel", n)
            icon.Size = UDim2.new(0, 24, 0, 24)
            icon.Position = UDim2.new(0, 10, 0.5, -12)
            icon.BackgroundTransparency = 1
            icon.Image = ResolveIcon(iconName)
            icon.ZIndex = 52
        end
        
        local tl = Instance.new("TextLabel", n)
        tl.Size = UDim2.new(1, -45, 0, 20)
        tl.Position = UDim2.new(0, 40, 0, 5)
        tl.BackgroundTransparency = 1
        tl.Text = title
        tl.TextColor3 = ACCENT
        tl.Font = Enum.Font.GothamBold
        tl.TextSize = 13
        tl.TextXAlignment = Enum.TextXAlignment.Left
        tl.ZIndex = 52
        
        local ml = Instance.new("TextLabel", n)
        ml.Size = UDim2.new(1, -45, 0, 35)
        ml.Position = UDim2.new(0, 40, 0, 25)
        ml.BackgroundTransparency = 1
        ml.Text = message
        ml.TextColor3 = NoirColors.SwitchColor
        ml.TextWrapped = true
        ml.TextXAlignment = Enum.TextXAlignment.Left
        ml.TextYAlignment = Enum.TextYAlignment.Top
        ml.Font = Enum.Font.Gotham
        ml.TextSize = 11
        ml.ZIndex = 52
        
        TweenService:Create(n, TweenInfo.new(0.5, Enum.EasingStyle.Back), {
            Position = UDim2.new(1, -280, 0.8, 0)
        }):Play()
        
        task.delay(4, function()
            TweenService:Create(n, TweenInfo.new(0.5), {
                Position = UDim2.new(1, 20, n.Position.Y.Scale, n.Position.Y.Offset),
                BackgroundTransparency = 1
            }):Play()
            task.wait(0.5)
            n:Destroy()
        end)
    end
    
    -- ============================================
    -- 11. RETURN
    -- ============================================
    Window._frame = WindowFrame
    Window._leftMenu = LeftMenu
    Window._rightMenu = RightMenu
    Window._tabScrolling = TabScrolling
    Window._tabContainer = TabContainer
    
    table.insert(NoirUI._windows, Window)
    
    return Window
end

return NoirUI
