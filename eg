            -- Reset all tabs
            for _, btn in pairs(TabScrolling:GetChildren()) do
                if btn:IsA("TextButton") then
                    local icon = btn:FindFirstChildWhichIsA("TextLabel")
                    local label = btn:FindFirstChildOfClass("TextLabel")
                    local hl = btn:FindFirstChild("Highlight")
                    if icon then icon.TextTransparency = 0.5 end
                    if label then label.TextTransparency = 0.5 end
                    if hl then hl.BackgroundTransparency = 1 end
                end
            end
            
            -- Highlight this tab
            TabIcon.TextTransparency = 0
            TabLabel.TextTransparency = 0
            Highlight.BackgroundTransparency = 0
            TabIcon.TextColor3 = ACCENT
        end
        
